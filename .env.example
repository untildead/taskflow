# ─── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string. Use Neon (https://neon.tech) or Railway.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com
# Authorized redirect URI (dev):  http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod): https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Public app URL — used by Auth.js for callbacks (set to your Render URL in prod)
AUTH_URL="http://localhost:3000"
